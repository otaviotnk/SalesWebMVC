@model SalesWebMVC.Models.ViewModels.HomeIndexViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="jumbotron" style="padding: 24px 32px; margin-bottom: 24px;">
    <h2 style="margin-top: 0;">Sales Dashboard</h2>
    <p class="text-muted">Overview of your team's sales performance.</p>
    <a class="btn btn-primary" asp-controller="SalesRecords" asp-action="Index">
        <span class="glyphicon glyphicon-list-alt"></span> Sales Records
    </a>
    <a class="btn btn-default" asp-controller="Sellers" asp-action="Index">
        <span class="glyphicon glyphicon-user"></span> Sellers
    </a>
    <a class="btn btn-default" asp-controller="Departments" asp-action="Index">
        <span class="glyphicon glyphicon-th-large"></span> Departments
    </a>
</div>

<div class="row">
    <div class="col-sm-6 col-md-3">
        <div class="panel panel-success">
            <div class="panel-body">
                <div class="row">
                    <div class="col-xs-3">
                        <span class="glyphicon glyphicon-usd" style="font-size: 40px;"></span>
                    </div>
                    <div class="col-xs-9 text-right">
                        <p class="text-muted" style="margin-bottom: 2px;">Total Revenue</p>
                        <h4 style="margin-top: 0;">@Model.TotalRevenue.ToString("C2")</h4>
                    </div>
                </div>
            </div>
            <div class="panel-footer text-right" style="padding: 4px 12px;">
                <small class="text-muted">Billed sales</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="panel panel-warning">
            <div class="panel-body">
                <div class="row">
                    <div class="col-xs-3">
                        <span class="glyphicon glyphicon-time" style="font-size: 40px;"></span>
                    </div>
                    <div class="col-xs-9 text-right">
                        <p class="text-muted" style="margin-bottom: 2px;">Pending Sales</p>
                        <h4 style="margin-top: 0;">@Model.PendingSales</h4>
                    </div>
                </div>
            </div>
            <div class="panel-footer text-right" style="padding: 4px 12px;">
                <small class="text-muted">Awaiting billing</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="panel panel-primary">
            <div class="panel-body">
                <div class="row">
                    <div class="col-xs-3">
                        <span class="glyphicon glyphicon-user" style="font-size: 40px;"></span>
                    </div>
                    <div class="col-xs-9 text-right">
                        <p class="text-muted" style="margin-bottom: 2px;">Sellers</p>
                        <h4 style="margin-top: 0;">@Model.TotalSellers</h4>
                    </div>
                </div>
            </div>
            <div class="panel-footer text-right" style="padding: 4px 12px;">
                <a asp-controller="Sellers" asp-action="Index"><small>View all</small></a>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="panel panel-info">
            <div class="panel-body">
                <div class="row">
                    <div class="col-xs-3">
                        <span class="glyphicon glyphicon-th-large" style="font-size: 40px;"></span>
                    </div>
                    <div class="col-xs-9 text-right">
                        <p class="text-muted" style="margin-bottom: 2px;">Departments</p>
                        <h4 style="margin-top: 0;">@Model.TotalDepartments</h4>
                    </div>
                </div>
            </div>
            <div class="panel-footer text-right" style="padding: 4px 12px;">
                <a asp-controller="Departments" asp-action="Index"><small>View all</small></a>
            </div>
        </div>
    </div>
</div>

<div class="panel panel-default">
    <div class="panel-heading">
        <h3 class="panel-title">
            <span class="glyphicon glyphicon-shopping-cart"></span> Recent Sales
        </h3>
    </div>
    <div class="panel-body" style="padding: 0;">
        <table class="table table-striped table-hover" style="margin-bottom: 0;">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Seller</th>
                    <th>Department</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sale in Model.RecentSales)
                {
                    <tr>
                        <td>@sale.Date.ToString("dd/MM/yyyy")</td>
                        <td>@sale.Seller.Name</td>
                        <td>@sale.Seller.Department.Name</td>
                        <td>@sale.Amount.ToString("C2")</td>
                        <td>
                            @switch (sale.Status)
                            {
                                case SalesWebMVC.Models.Enums.SalesStatus.Billed:
                                    <span class="label label-success">Billed</span>
                                    break;
                                case SalesWebMVC.Models.Enums.SalesStatus.Pending:
                                    <span class="label label-warning">Pending</span>
                                    break;
                                case SalesWebMVC.Models.Enums.SalesStatus.Canceled:
                                    <span class="label label-danger">Canceled</span>
                                    break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="panel-footer text-right">
        <a asp-controller="SalesRecords" asp-action="Index">View all sales records →</a>
    </div>
</div>
