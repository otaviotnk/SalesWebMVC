@model SalesWebMVC.Models.Seller

@{
    ViewData["Title"] = "Delete Seller";
}

<div class="panel panel-danger">
    <div class="panel-heading">
        <h3 class="panel-title">
            <span class="glyphicon glyphicon-trash"></span> Delete Seller
        </h3>
    </div>
    <div class="panel-body">
        <p class="text-danger"><strong>Are you sure you want to delete this seller?</strong></p>
        <dl class="dl-horizontal">
            <dt>@Html.DisplayNameFor(model => model.Name)</dt>
            <dd>@Html.DisplayFor(model => model.Name)</dd>
            <dt>@Html.DisplayNameFor(model => model.Email)</dt>
            <dd>@Html.DisplayFor(model => model.Email)</dd>
            <dt>@Html.DisplayNameFor(model => model.BirthDate)</dt>
            <dd>@Html.DisplayFor(model => model.BirthDate)</dd>
            <dt>@Html.DisplayNameFor(model => model.BaseSalary)</dt>
            <dd>@Html.DisplayFor(model => model.BaseSalary)</dd>
        </dl>
    </div>
    <div class="panel-footer">
        <form asp-action="Delete" style="display: inline;">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger btn-sm">
                <span class="glyphicon glyphicon-trash"></span> Confirm Delete
            </button>
        </form>
        <a asp-action="Index" class="btn btn-default btn-sm">Cancel</a>
    </div>
</div>